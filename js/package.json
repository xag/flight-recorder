  "type": "module",
  "license": "MIT",
  "author": "Xavier Grehant",
  "homepage": "https://github.com/xag/flight-recorder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xag/flight-recorder.git",
    "directory": "js"
  },
  "bugs": {
    "url": "https://github.com/xag/flight-recorder/issues"
  },
  "keywords": [
    "record",
    "replay",
    "deterministic",
    "testing",
    "debugging",
    "simulation",
    "observability",
    "nondeterminism",
    "regression"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./src/index.js",
    "./spec": "./src/spec/validate.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test"
  },
  "publishConfig": {
    "access": "public"
  }
}
